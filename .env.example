# ─── Xappy Platform — Root Environment Variables ─────────────────
# Copy this file to .env and fill in real values.
# Only secrets and per-environment overrides belong here;
# sane defaults are baked into docker-compose.yml.

# ─── PostgreSQL (shared by Health / Oil / Property) ──────────────
POSTGRES_PASSWORD=xappy_secret_2024

# ─── PostgreSQL (CereBro / Moodcraft) ───────────────────────────
CEREBRO_POSTGRES_PASSWORD=cerebro_dev_password

# ─── JWT / App Secret ───────────────────────────────────────────
SECRET_KEY=xappy-secret-key-change-in-production

# ─── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Anthropic (optional, for CereBro) ──────────────────────────
ANTHROPIC_API_KEY=

# ─── WhatsApp — Health ───────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your-health-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-health-phone-number-id
WHATSAPP_VERIFY_TOKEN=xappy_verify_token

# ─── WhatsApp — Oil ─────────────────────────────────────────────
OIL_WHATSAPP_ACCESS_TOKEN=your-oil-whatsapp-access-token
OIL_WHATSAPP_PHONE_NUMBER_ID=your-oil-phone-number-id
OIL_WHATSAPP_VERIFY_TOKEN=mobirizer_2025_d23
OIL_WHATSAPP_APP_SECRET=your-oil-whatsapp-app-secret

# ─── WhatsApp — Property ────────────────────────────────────────
PROPERTY_WHATSAPP_ACCESS_TOKEN=your-property-whatsapp-access-token
PROPERTY_WHATSAPP_PHONE_NUMBER_ID=your-property-phone-number-id
PROPERTY_WHATSAPP_VERIFY_TOKEN=xappy_2026_uk
PROPERTY_WHATSAPP_APP_SECRET=your-property-whatsapp-app-secret

# ─── Bhashini (Voice / Translation) ─────────────────────────────
BHASHINI_API_KEY=your-bhashini-api-key
BHASHINI_USER_ID=your-bhashini-user-id

# ─── Vector DB — Pinecone (managed) ─────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=cerebro-memory

# ─── Vector DB — Qdrant (self-hosted, via docker-compose) ───────
QDRANT_API_KEY=

# ─── LangSmith (AI observability, optional) ─────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=cerebro-ai

# ─── Moodcraft / CereBro ────────────────────────────────────────
API_SECRET_KEY=change-this-in-production
NEXTAUTH_SECRET=cerebro-local-dev-secret-change-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── XappyIO Web ────────────────────────────────────────────────
XAPPY_WEB_API_URL=http://localhost:5051

# ─── Debug ───────────────────────────────────────────────────────
DEBUG=false
