# CereBro AI Service - Environment Variables

# ─── App Configuration ───────────────────────────────────────────
DEBUG=false
API_PREFIX=/api/v1

# ─── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Anthropic (Optional) ────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Vector Database - Pinecone (Managed) ────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=cerebro-memory

# ─── Vector Database - Qdrant (Self-hosted alternative) ─────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/cerebro

# ─── LangSmith (Observability) ───────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=cerebro-ai

# ─── Security ────────────────────────────────────────────────────
API_SECRET_KEY=change-this-in-production
CORS_ORIGINS=["http://localhost:3000"]
