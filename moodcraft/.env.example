# Database
DATABASE_URL="postgresql://cerebro:cerebro_dev_password@localhost:5432/cerebro"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OpenAI
OPENAI_API_KEY=""

# NLP Service (Python FastAPI with LangChain/LangGraph)
NLP_SERVICE_URL="http://localhost:8000"

# Vector Database - Pinecone (Managed)
PINECONE_API_KEY=""
PINECONE_ENVIRONMENT="us-east-1"
PINECONE_INDEX_NAME="cerebro-memory"

# Vector Database - Qdrant (Self-hosted alternative)
# Use this if you prefer self-hosted vector storage
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""

# LangSmith (Optional - AI Observability)
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="cerebro-ai"

# Anthropic (Optional - for Claude models)
ANTHROPIC_API_KEY=""

# Encryption
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"

# Insurance API
INSURANCE_HMAC_SECRET="your-hmac-secret-for-insurance-api"

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
